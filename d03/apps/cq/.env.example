# cq.sh creates .env from this file (or from scratch) and fills CQ_JWT_SECRET if empty.
#
# CQ_JWT_SECRET — server-only key the team API uses to sign JWTs (browser login sessions).
# It is not your review-UI password, not an MCP client secret, and not shown to agents.
CQ_JWT_SECRET=
#
# cq-team-api runs as this uid/gid (compose `user:`); ${DOCKER_DL}/cq/data is chowned to match.
CQ_TEAM_API_UID=1000
CQ_TEAM_API_GID=1000
