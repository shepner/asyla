# Dispatcher automation env. Copy to .config/env and set values.
# Required for container: OpenBao token so the dispatcher can fetch CURSOR_API_KEY at runtime.
#
# OPENBAO_ADDR=https://vault.asyla.org
# OPENBAO_TOKEN=<root-or-scoped-token>
# Or use a token file (e.g. from deploy-devteam.sh):
# OPENBAO_TOKEN_FILE=/path/to/token
#
# Optional: bind-mount host _runs for persistent run logs (default uses a named volume)
# HUB_RUNS_DIR=~/scripts/knowledge-hub
#
# Optional: poll interval in seconds (default 300)
# DISPATCH_POLL_INTERVAL=300
