# Plane Community Edition environment
# Copy to .env and set secure values for all passwords/keys

# Docker data location (set by common.env)
# DOCKER_DL=/mnt/docker

APP_DOMAIN=plane.asyla.org
APP_RELEASE=v1.2.2

WEB_URL=https://plane.asyla.org
CORS_ALLOWED_ORIGINS=https://plane.asyla.org

# Database — CHANGE PASSWORD
POSTGRES_USER=plane
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
PGDATABASE=plane

# RabbitMQ — CHANGE PASSWORD
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=CHANGE_ME_MQ_PASSWORD
RABBITMQ_VHOST=plane

# MinIO (S3-compatible storage) — CHANGE KEYS
AWS_ACCESS_KEY_ID=CHANGE_ME_MINIO_ACCESS
AWS_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_SECRET
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads

# Application secrets — CHANGE THESE
SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY
LIVE_SERVER_SECRET_KEY=CHANGE_ME_LIVE_SECRET

# Misc
USE_MINIO=1
DEBUG=0
FILE_SIZE_LIMIT=5242880
API_KEY_RATE_LIMIT=60/minute
MINIO_ENDPOINT_SSL=0
# When behind external Caddy, proxy listens HTTP only. CERT_ACME_CA must be set (compose default) or proxy Caddyfile fails to parse.
SITE_ADDRESS=:80
