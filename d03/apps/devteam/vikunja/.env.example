# Vikunja environment variables
# Copy to .env and fill in values. Generated secrets can be created with:
#   ~/scripts/d03/apps/devteam/vikunja/generate-env.sh

# Public URL (used by the frontend and API)
VIKUNJA_PUBLIC_URL=https://vikunja.asyla.org

# Database credentials (generated by generate-env.sh)
POSTGRES_USER=vikunja
POSTGRES_DB=vikunja
POSTGRES_PASSWORD=changeme

# JWT secret (generated by generate-env.sh)
JWT_SECRET=changeme

# Enable user registration — set true only during initial setup, then set to false
ENABLE_REGISTRATION=false
